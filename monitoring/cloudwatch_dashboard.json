{
  "Comment": "CloudWatch Dashboard for arXiv Summarizer SageMaker Endpoint",
  "Instructions": "Replace ENDPOINT_NAME and REGION with your values, then import this JSON in the CloudWatch console under Dashboards > Create dashboard > JSON.",
  "ENDPOINT_NAME": "arxiv-summarizer-endpoint",
  "REGION": "us-east-1",
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Endpoint Invocations",
        "metrics": [
          [
            "AWS/SageMaker",
            "Invocations",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic"
          ]
        ],
        "period": 300,
        "stat": "Sum",
        "region": "us-east-1",
        "view": "timeSeries"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Model Latency (P50 / P95 / P99)",
        "metrics": [
          [
            "AWS/SageMaker",
            "ModelLatency",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic",
            { "stat": "p50", "label": "p50" }
          ],
          [
            "AWS/SageMaker",
            "ModelLatency",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic",
            { "stat": "p95", "label": "p95" }
          ],
          [
            "AWS/SageMaker",
            "ModelLatency",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic",
            { "stat": "p99", "label": "p99" }
          ]
        ],
        "period": 300,
        "region": "us-east-1",
        "view": "timeSeries",
        "yAxis": {
          "left": {
            "label": "Microseconds"
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Error Rate (4XX + 5XX)",
        "metrics": [
          [
            "AWS/SageMaker",
            "Invocation4XXErrors",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic",
            { "label": "4XX (Client Errors)" }
          ],
          [
            "AWS/SageMaker",
            "Invocation5XXErrors",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic",
            { "label": "5XX (Server Errors)" }
          ]
        ],
        "period": 300,
        "stat": "Sum",
        "region": "us-east-1",
        "view": "timeSeries"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "CPU + Memory Utilization",
        "metrics": [
          [
            "AWS/SageMaker",
            "CPUUtilization",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic"
          ],
          [
            "AWS/SageMaker",
            "MemoryUtilization",
            "EndpointName",
            "arxiv-summarizer-endpoint",
            "VariantName",
            "AllTraffic"
          ]
        ],
        "period": 300,
        "stat": "Average",
        "region": "us-east-1",
        "view": "timeSeries",
        "yAxis": {
          "left": {
            "label": "Percent",
            "min": 0,
            "max": 100
          }
        }
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 12,
      "width": 24,
      "height": 2,
      "properties": {
        "markdown": "## Model Monitor\nCheck SageMaker Model Monitor reports in S3: `s3://YOUR_BUCKET/arxiv-summarizer/monitor-reports/`\n\nData Capture logs: `s3://YOUR_BUCKET/arxiv-summarizer/data-capture/arxiv-summarizer-endpoint/`"
      }
    }
  ]
}
